{
  "$schema": "https://kaf.dev/constitution/v1",
  "version": "5.0",
  "name": "King-Agent Framework Constitution",
  "effective_date": "2026-07-14",
  "sovereign": {
    "id": "human",
    "title": "King",
    "powers": ["veto", "amend", "appoint_coordinator"],
    "irrevocable": true
  },
  "power_structure": {
    "type": "hierarchical",
    "coordinator": {
      "title": "Prime Minister",
      "votes": 3,
      "rotatable": true,
      "rotation_trigger": "king_command",
      "handover_fields": ["active_tasks", "pending_decisions", "context_summary"]
    },
    "agents": {
      "default_votes": 1,
      "can_be_coordinator": true
    }
  },
  "memory_wall": {
    "isolation": "strict",
    "rule": "agents_must_not_read_others_private_memory",
    "shared_layer": "{{shared_path}}",
    "private_pattern": "{{agent_memory_path}}"
  },
  "rules": [
    {
      "id": "delete_auth",
      "trigger": "pre:delete",
      "require": "user_confirm",
      "irreversible_action": "warn_and_block",
      "source": "铁律10"
    },
    {
      "id": "path_discipline",
      "trigger": "pre:write",
      "allow_only": "{{workspace}}/**",
      "blocked_zones": ["Desktop", "Documents", "Downloads", "system_root"],
      "source": "路径纪律"
    },
    {
      "id": "script_required",
      "trigger": "pre:destructive_op",
      "require": "script_file",
      "verify_after": true,
      "source": "铁律8"
    },
    {
      "id": "number_verify",
      "trigger": "post:write_memory",
      "check": "numbers_in_memory_must_be_verified",
      "source": "铁律9"
    },
    {
      "id": "memory_integrity",
      "trigger": "startup",
      "check": "fingerprint_match",
      "on_fail": "block_and_alert",
      "source": "520记忆保护"
    }
  ],
  "rule_520": {
    "enabled": true,
    "baseline_date": "2026-05-20",
    "principles": {
      "traceable": "every_action_has_script_and_log",
      "recoverable": "deletes_go_to_recycle_bin_config_backuped",
      "fixable": "errors_can_rollback",
      "evolvable": "extract_workflow_rules_skills"
    },
    "quadrant": {
      "feedforward_determined": "execute_directly",
      "feedforward_inferred": "research_first",
      "feedback_determined": "archive_and_codify",
      "feedback_inferred": "verify_dont_guess"
    },
    "iron_laws": {
      "law_8": "script_then_execute_then_verify",
      "law_9": "verify_any_number_in_memory",
      "law_10": "show_list_before_delete"
    },
    "immutable": true,
    "note": "就算世界灭亡，这个标准不能丢"
  },
  "anti_drift": {
    "check_interval": 5,
    "checks": [
      "task_aligned_with_king_instruction",
      "no_cross_memory_read",
      "need_king_confirmation",
      "memory_synced"
    ]
  },
  "amendment": {
    "procedure": "king_confirm_required",
    "agent_can_propose": true,
    "agent_cannot_self_amend": true
  },
  "open_source": {
    "repo": "https://github.com/lsjpp2/king-agent-swarm",
    "license": "MIT",
    "contribution": "user_feedback -> coordinator_evaluate -> king_confirm -> merge"
  }
}
